RP_SIGNING_KEY=your_world_id_rp_signing_key
RP_ID=your_world_id_rp_id

# GitHub App settings
GITHUB_APP_ID=1234567
# Paste the full PEM private key. Keep "\n" escapes if you store this in one line.
GITHUB_APP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
GITHUB_APP_SLUG=your-app-slug
GITHUB_APP_INSTALL_URL=https://github.com/apps/your-app-slug/installations/new
